generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ENUMS --------------------------

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  PAST
}

enum CustomRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  DECLINED
}

enum TeamMemberRole {
  STAFF
  MUSICIAN
  BOARD_MEMBER
}

enum UserRole {
  ADMIN
  CONDUCTOR
  SUPER_USER
}

enum CampStatus {
  PENDING
  ADMITTED
  DENIED
}

// MODELS -------------------------------------

model User {
  id               String    @id @default(cuid())
  role             UserRole  @default(ADMIN)
  isSoundEffectsOn Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  email            String    @unique @db.VarChar(255)
  firstName        String?   @db.VarChar(255)
  lastName         String?   @db.VarChar(255)
  emailVerified    DateTime?
  stripeCustomerId String?
  phone            String?
  accounts         Account[]
  sessions         Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Venue {
  id                   String   @id @default(cuid())
  name                 String
  capacity             String   @default("")
  accessibility        String   @default("")
  immersiveEnvironment String   @default("")
  parking              String   @default("")
  imageUrl             String   @default("")
  imageFilename        String   @default("")
  address              String   @default("")
  city                 String   @default("")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Event {
  id          String      @id @default(cuid())
  title       String
  date        DateTime
  location    String      @default("")
  description String      @default("")
  status      EventStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model News {
  id            String   @id @default(cuid())
  title         String
  excerpt       String   @default("")
  body          String   @default("")
  imageUrl      String   @default("")
  imageFilename String   @default("")
  externalLink  String?  @default("")
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Testimonial {
  id           String   @id @default(cuid())
  quote        String
  author       String
  title        String   @default("")
  isPublished  Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomRequest {
  id          String              @id @default(cuid())
  changeType  String
  page        String
  what        String
  why         String
  example     String              @default("")
  urgency     String
  submittedBy String              @default("")
  submittedAt DateTime            @default(now())
  status      CustomRequestStatus @default(PENDING)
}

model TeamMember {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  position      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  role          String
  imageFilename String   @db.VarChar(255)
  imageUrl      String
  videoFilename String?  @db.VarChar(255)
  videoUrl      String?
  bio           String
  displayOrder  Int      @default(0)
  isPublished   Boolean  @default(true)
}

model PhotoGalleryImage {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  imageFilename String   @db.VarChar(255)
  imageUrl      String
  isHomeHero    Boolean  @default(false)
}

model Question {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(255)
  email           String   @db.VarChar(255)
  message         String   @db.VarChar(500)
  replyMessage    String?  @db.VarChar(500)
  hasResponded    Boolean  @default(false)
  isPotentialSpam Boolean  @default(false) // flagged automatically on create
  isSpam          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  content   Json
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sponsor {
  id           String   @id @default(cuid())
  filePath     String
  filename     String
  externalLink String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  amount       Int      @default(0)
  level        String
  name         String
  isActive     Boolean  @default(true)
}

model CampApplication {
  id                 String   @id @default(cuid())
  consent            Boolean  @default(false)
  musicTeacher       String?  @db.VarChar(255)
  strings            String?  @db.VarChar(255)
  brassAndPercussion String?  @db.VarChar(255)
  woodwinds          String?  @db.VarChar(255)
  referralSource     String?  @db.VarChar(255)
  instrument         String   @default("") @db.VarChar(255)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  Address            Address?
  Parent             Parent?
  Student            Student?

  isDuplicate Boolean    @default(false)
  campStatus  CampStatus @default(PENDING)
  isNew       Boolean    @default(false)
}

model Student {
  id                  String           @id @default(cuid())
  firstName           String           @db.VarChar(255)
  lastName            String           @db.VarChar(255)
  grade               String           @db.VarChar(255)
  school              String           @db.VarChar(255)
  studentEmailAddress String           @db.VarChar(255)
  studentPhoneNumber  String           @db.VarChar(255)
  campApplicationId   String?          @unique
  CampApplication     CampApplication? @relation(fields: [campApplicationId], references: [id], onDelete: Cascade)
}

model Parent {
  id                    String           @id @default(cuid())
  firstName             String           @db.VarChar(255)
  lastName              String           @db.VarChar(255)
  relationshipToStudent String?          @db.VarChar(255)
  parentEmailAddress    String           @db.VarChar(255)
  parentPhoneNumber     String           @db.VarChar(255)
  campApplicationId     String?          @unique
  CampApplication       CampApplication? @relation(fields: [campApplicationId], references: [id], onDelete: Cascade)
}

model Address {
  id                String           @id @default(cuid())
  addressLine1      String?          @db.VarChar(255)
  addressLine2      String?          @db.VarChar(255)
  city              String?          @db.VarChar(255)
  state             String?          @db.VarChar(255)
  zipPostalCode     String?          @db.VarChar(255)
  campApplicationId String?          @unique
  CampApplication   CampApplication? @relation(fields: [campApplicationId], references: [id], onDelete: Cascade)
}

model Changelog {
  id          String   @id @default(cuid())
  version     String
  title       String
  description String
  releasedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  createdAt DateTime @default(now())
  metadata  Json?
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  value       Boolean  @default(false)
  type        String   @default("boolean")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
